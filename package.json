{
  "name": "xiangqi",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "client/electron/main.cjs",
  "scripts": {
    "server": "node server/server.js",
    "build:client": "tsc --project tsconfig.json",
    "check:client": "tsc --project tsconfig.json --noEmit",
    "build:pgn-db": "node scripts/build-pgn-sqlite.cjs",
    "dist:mac": "npm run build:client && electron-builder --mac dmg zip",
    "dist:linux": "npm run build:client && electron-builder --linux AppImage deb tar.gz",
    "start": "npm run build:client && electron .",
    "electron": "npm run build:client && electron ."
  },
  "build": {
    "appId": "ca.tomliu.xiangqi",
    "productName": "xiangqi",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "client/**/*",
      "package.json",
      "!client/pgns/**/*"
    ],
    "extraResources": [
      {
        "from": "pikafish",
        "to": "pikafish"
      },
      {
        "from": "pikafish.nnue",
        "to": "pikafish.nnue"
      },
      {
        "from": "client/pgns/library.sqlite",
        "to": "pgns/library.sqlite"
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Game",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ]
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}
