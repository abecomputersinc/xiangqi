{
  "name": "xiangqi",
  "version": "1.0.4",
  "description": "A desktop Xiangqi game.",
  "author": {
    "name": "Hangcheng Liu",
    "email": "mail@tomliu.ca"
  },
  "private": true,
  "type": "module",
  "main": "client/electron/main.cjs",
  "scripts": {
    "server": "node server/server.js",
    "build:client": "tsc --project tsconfig.json",
    "check:client": "tsc --project tsconfig.json --noEmit",
    "dist:mac": "npm run build:client && electron-builder --mac dmg zip --publish never",
    "dist:mac:arm64": "npm run build:client && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:linux": "npm run build:client && electron-builder --linux AppImage deb tar.gz --publish never",
    "dist:win": "npm run build:client && electron-builder --win nsis zip --x64 --publish never",
    "start": "npm run build:client && electron .",
    "electron": "npm run build:client && electron ."
  },
  "build": {
    "appId": "ca.tomliu.xiangqi",
    "productName": "xiangqi",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "afterPack": "scripts/clean-mac-xattrs.cjs",
    "files": [
      "client/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.games",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "pikafish",
          "to": "pikafish"
        },
        {
          "from": "pikafish.nnue",
          "to": "pikafish.nnue"
        }
      ],
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "extraResources": [
        {
          "from": "pikafish.exe",
          "to": "pikafish.exe"
        },
        {
          "from": "pikafish.nnue",
          "to": "pikafish.nnue"
        }
      ],
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Game",
      "extraResources": [
        {
          "from": "pikafish",
          "to": "pikafish"
        },
        {
          "from": "pikafish.nnue",
          "to": "pikafish.nnue"
        }
      ],
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ]
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}
