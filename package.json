{
  "name": "xiangqi",
  "version": "1.0.17",
  "description": "A desktop Xiangqi game.",
  "author": {
    "name": "Hangcheng Liu",
    "email": "mail@tomliu.ca"
  },
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/src/main/main.cjs",
  "scripts": {
    "server": "node ../xiangqiserver/server.js",
    "build": "tsc --project tsconfig.json",
    "check": "tsc --project tsconfig.json --noEmit",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --mac dmg zip --arm64 --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb tar.gz --publish never",
    "dist:win": "npm run build && electron-builder --win nsis zip --x64 --publish never",
    "start": "npm run build && electron .",
    "electron": "npm run build && electron ."
  },
  "build": {
    "appId": "ca.tomliu.xiangqi",
    "productName": "xiangqi",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "src/renderer/index.html",
      "src/renderer/styles.css",
      "sound/**/*",
      "dist/src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.games",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "pikafish-engines",
          "to": "pikafish-engines"
        },
        {
          "from": "pikafish.nnue",
          "to": "pikafish.nnue"
        }
      ],
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "extraResources": [
        {
          "from": "pikafish-engines",
          "to": "pikafish-engines"
        },
        {
          "from": "pikafish.nnue",
          "to": "pikafish.nnue"
        }
      ],
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Game",
      "extraResources": [
        {
          "from": "pikafish-engines",
          "to": "pikafish-engines"
        },
        {
          "from": "pikafish.nnue",
          "to": "pikafish.nnue"
        }
      ],
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ]
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}
